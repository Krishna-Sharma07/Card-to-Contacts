<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Google Play services / ML Kit's own manifest declares these
         defensively even though on-device text recognition never uses the
         network. Force them out of the release build so the APK matches
         this app's actual no-internet, local-only behavior. -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="remove" />

</manifest>
